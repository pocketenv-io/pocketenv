amends "../../schema/lexicon.pkl"

lexicon = 1
id = "io.pocketenv.service.addService"
defs = new Mapping<String, Procedure> {
  ["main"] {
    type = "procedure"
    parameters {
      type = "params"
      required = List("sandboxId")
      properties {
        ["sandboxId"] = new StringType {
          type = "string"
          description = "The ID of the sandbox to which the service belongs."
        }
      }
    }
    input {
      encoding = "application/json"
      schema {
        type = "object"
        required = List("service")
        properties {
          ["service"] = new Ref {
            type = "ref"
            ref = "io.pocketenv.service.defs#service"
          }
        }
      }
    }
  }
}
