amends "../../schema/lexicon.pkl"

lexicon = 1
id = "io.pocketenv.sandbox.putTailscaleAuthKey"
defs = new Mapping<String, Procedure> {
  ["main"] {
    type = "procedure"
    description =
      "Store a Tailscale Auth Key for the sandbox. This Auth Key will be used to authenticate with the Tailscale API and manage the sandbox's Tailscale node."
    input {
      encoding = "application/json"
      schema = new ObjectType {
        type = "object"
        required = List("id", "authKey")
        properties {
          ["id"] = new StringType {
            type = "string"
            description = "The sandbox ID."
          }
          ["authKey"] = new StringType {
            type = "string"
            description = "The Tailscale Auth Key (encrypted) to store for the sandbox."
          }
          ["redacted"] = new StringType {
            type = "string"
            description = "The redacted SSH key."
          }
        }
      }
    }
    output {
      encoding = "application/json"
      schema = new Ref {
        type = "ref"
        ref = "io.pocketenv.sandbox.defs#tailscaleAuthKeyView"
      }
    }
  }
}
