amends "../../schema/lexicon.pkl"

lexicon = 1
id = "io.pocketenv.volume.updateVolume"
defs = new Mapping<String, Procedure> {
  ["main"] {
    type = "procedure"
    input {
      encoding = "application/json"
      schema {
        type = "object"
        required = List("id", "volume")
        properties {
          ["id"] = new StringType {
            type = "string"
            description = "The ID of the volume to update."
          }
          ["volume"] = new Ref {
            type = "ref"
            ref = "io.pocketenv.volume.defs#volume"
          }
        }
      }
    }
  }
}
