amends "../../schema/lexicon.pkl"

lexicon = 1
id = "io.pocketenv.sandbox.createSandbox"
defs = new Mapping<String, Procedure> {
  ["main"] {
    type = "procedure"
    description = "Create a sandbox"
    input {
      encoding = "application/json"
      schema {
        type = "object"
        required = List("base")
        properties {
          ["base"] = new StringType {
            type = "string"
            description =
              "The base sandbox URI to clone from, e.g. a template or an existing sandbox."
          }
          ["name"] = new StringType {
            type = "string"
            description = "The name of the sandbox"
            minLength = 1
          }
          ["description"] = new StringType {
            type = "string"
            description = "A description for the sandbox"
          }
          ["provider"] = new StringType {
            type = "string"
            enum = List("daytona", "vercel", "cloudflare", "deno", "sprites")
            description =
              "The provider to create the sandbox on, e.g. 'daytona', 'vercel', 'cloudflare', etc."
          }
          ["topics"] = new Array {
            type = "array"
            description = "A list of topics/tags to associate with the sandbox"
            items = new StringType {
              type = "string"
              maxLength = 50
            }
          }
          ["repo"] = new StringType {
            type = "string"
            description =
              "A git repository URL to clone into the sandbox, e.g. a GitHub/Tangled repo."
          }
          ["vcpus"] = new IntegerType {
            type = "integer"
            description = "The number of virtual CPUs to allocate for the sandbox"
            minimum = 1
          }
          ["memory"] = new IntegerType {
            type = "integer"
            description = "The amount of memory (in GB) to allocate for the sandbox"
            minimum = 1
          }
          ["disk"] = new IntegerType {
            type = "integer"
            description = "The amount of disk space (in GB) to allocate for the sandbox"
            minimum = 3
          }
          ["readme"] = new StringType {
            type = "string"
            description = "A URI to a README for the sandbox."
            format = "uri"
          }
          ["secrets"] = new Ref {
            type = "ref"
            ref = "io.pocketenv.sandbox.defs#secrets"
            description = "A list of secrets to add to the sandbox"
          }
          ["envs"] = new Ref {
            type = "ref"
            ref = "io.pocketenv.sandbox.defs#envs"
            description = "A list of environment variables to add to the sandbox"
          }
          ["keepAlive"] = new BooleanType {
            type = "boolean"
            description =
              "Prevent the sandbox from being automatically stop after a period of inactivity. Use with caution, as this may lead to increased costs."
          }
          ["spriteToken"] = new StringType {
            type = "string"
            description = "A token (encrypted) for accessing sprite resources"
          }
          ["redactedSpriteToken"] = new StringType {
            type = "string"
            description = "A redacted token for accessing sprite resources"
          }
          ["denoDeployToken"] = new StringType {
            type = "string"
            description = "A token (encrypted) for accessing Deno Deploy resources"
          }
          ["redactedDenoDeployToken"] = new StringType {
            type = "string"
            description = "A redacted token for accessing Deno Deploy resources"
          }
          ["daytonaApiKey"] = new StringType {
            type = "string"
            description = "A token (encrypted) for accessing Daytona resources"
          }
          ["redactedDaytonaApiKey"] = new StringType {
            type = "string"
            description = "A redacted token for accessing Daytona resources"
          }
          ["daytonaOrganizationId"] = new StringType {
            type = "string"
            description = "The organization ID for Daytona resources"
          }
          ["vercelApiToken"] = new StringType {
            type = "string"
            description = "A token (encrypted) for accessing Vercel resources"
          }
          ["redactedVercelApiToken"] = new StringType {
            type = "string"
            description = "A redacted token for accessing Vercel resources"
          }
          ["vercelProjectId"] = new StringType {
            type = "string"
            description = "The project ID for Vercel resources"
          }
          ["vercelTeamId"] = new StringType {
            type = "string"
            description = "The team ID for Vercel resources"
          }
        }
      }
    }
    output {
      encoding = "application/json"
      schema = new Ref {
        type = "ref"
        ref = "io.pocketenv.sandbox.defs#sandboxViewBasic"
      }
    }
  }
}
