amends "../../schema/lexicon.pkl"

lexicon = 1
id = "io.pocketenv.service.deleteService"
defs = new Mapping<String, Procedure> {
  ["main"] {
    type = "procedure"
    parameters {
      type = "params"
      required = List("serviceId")
      properties {
        ["serviceId"] = new StringType {
          type = "string"
          description = "The ID of the service to delete."
        }
      }
    }
  }
}
