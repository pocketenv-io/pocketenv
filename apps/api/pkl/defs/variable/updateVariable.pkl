amends "../../schema/lexicon.pkl"

lexicon = 1
id = "io.pocketenv.variable.updateVariable"
defs = new Mapping<String, Procedure> {
  ["main"] {
    type = "procedure"
    input {
      encoding = "application/json"
      schema {
        type = "object"
        required = List("id", "variable")
        properties {
          ["id"] = new StringType {
            type = "string"
            description = "The ID of the variable to update."
          }
          ["variable"] = new Ref {
            type = "ref"
            ref = "io.pocketenv.variable.defs#variable"
          }
        }
      }
    }
  }
}
