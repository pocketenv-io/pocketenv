amends "../../schema/lexicon.pkl"

lexicon = 1
id = "io.pocketenv.secret.updateSecret"
defs = new Mapping<String, Procedure> {
  ["main"] {
    type = "procedure"
    input {
      encoding = "application/json"
      schema {
        type = "object"
        required = List("id", "secret")
        properties {
          ["id"] = new StringType {
            type = "string"
            description = "The ID of the secret to update."
          }
          ["secret"] = new Ref {
            type = "ref"
            ref = "io.pocketenv.secret.defs#secret"
          }
          ["redacted"] = new StringType {
            type = "string"
            description = "The redacted secret value."
          }
        }
      }
    }
  }
}
