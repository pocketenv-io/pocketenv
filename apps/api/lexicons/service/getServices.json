{
  "lexicon": 1,
  "id": "io.pocketenv.service.getServices",
  "defs": {
    "main": {
      "type": "query",
      "parameters": {
        "type": "params",
        "required": [
          "sandboxId"
        ],
        "properties": {
          "sandboxId": {
            "type": "string",
            "description": "The ID of the sandbox for which to retrieve services."
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "properties": {
            "services": {
              "type": "array",
              "items": {
                "type": "ref",
                "ref": "io.pocketenv.service.defs#serviceView"
              }
            }
          }
        }
      }
    }
  }
}
