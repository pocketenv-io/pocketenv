amends "../../schema/lexicon.pkl"

lexicon = 1
id = "io.pocketenv.sandbox.getBackups"
defs = new Mapping<String, Query> {
  ["main"] {
    type = "query"
    description = "Get the list of backups for a sandbox."
    parameters {
      type = "params"
      required = List("id")
      properties {
        ["id"] = new StringType {
          type = "string"
          description = "The sandbox ID."
        }
      }
    }
    output {
      encoding = "application/json"
      schema = new ObjectType {
        type = "object"
        properties {
          ["backups"] = new Array {
            type = "array"
            items = new Ref {
              ref = "io.pocketenv.port.defs#backupViewBasic"
            }
          }
        }
      }
    }
  }
}
