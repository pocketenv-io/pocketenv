amends "../../schema/lexicon.pkl"

lexicon = 1
id = "io.pocketenv.sandbox.createBackup"
defs = new Mapping<String, Procedure> {
  ["main"] {
    type = "procedure"
    description = "Create a backup of a sandbox by id"
    parameters {
      type = "params"
      required = List("id")
      properties {
        ["id"] = new StringType {
          type = "string"
          description = "The sandbox ID."
        }
      }
    }
    input {
      encoding = "application/json"
      schema = new ObjectType {
        type = "object"
        required = List("directory")
        properties {
          ["directory"] = new StringType {
            type = "string"
            description = "The directory to backup."
          }
          ["description"] = new StringType {
            type = "string"
            description = "An optional description for the backup."
          }
          ["ttl"] = new IntegerType {
            type = "integer"
            description =
              "The time-to-live (TTL) for the backup in seconds. After this time, the backup will be automatically deleted. If not provided, the backup will expire after 3 days."
          }
        }
      }
    }
    output {
      encoding = "application/json"
      schema = new Ref {
        type = "ref"
        ref = "io.pocketenv.sandbox.defs#backupViewBasic"
      }
    }
  }
}
